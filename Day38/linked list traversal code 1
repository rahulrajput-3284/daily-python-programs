class Node:

    def __init__(self, data):
        self.data = data
        self.next = None


# Step 1: Nodes banana
node1 = Node(10)
node2 = Node(20)
node3 = Node(30)
node4 = Node(40)

# Step 2: Nodes ko connect karna
node1.next = node2
node2.next = node3
node3.next = node4

# Step 3: Head
head = node1

# Step 4: Traversal
current = head

while current is not None:
    print(current.data)
    current = current.next