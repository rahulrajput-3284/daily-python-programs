def is_palindrome(n):

    temp = n
    rev = 0

    while n > 0:
        digit = n % 10
        rev = rev * 10 + digit
        n = n // 10

    if temp == rev:
        return True
    else:
        return False


num = 121

if is_palindrome(num):
    print("Palindrome")
else:
    print("Not Palindrome")