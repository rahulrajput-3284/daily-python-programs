arr = [25, 90, 14, 67, 3, 120, 45]

largest = arr[0]
second_largest = arr[0]

for i in arr:
    if i > largest:
        second_largest = largest
        largest = i

    elif i > second_largest and i != largest:
        second_largest = i

print("Largest =", largest)
print("Second Largest =", second_largest)