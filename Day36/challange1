arr = [25, 90, 14, 67, 3, 120, 45]

sum = 0
count = 0
maximum = arr[0]
minimum = arr[0]

for i in arr:
    sum = sum + i
    count = count + 1

    if i > maximum:
        maximum = i

    if i < minimum:
        minimum = i

print("Sum =", sum)
print("Count =", count)
print("Maximum =", maximum)
print("Minimum =", minimum)